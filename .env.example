# X Developer recent search API
X_BEARER_TOKEN=
X_QUERY=(AI OR "artificial intelligence" OR ChatGPT OR Claude OR Gemini) has:links -is:retweet -is:reply

# Vercel AI Gateway (optional; without it the site uses deterministic summaries)
AI_GATEWAY_API_KEY=
AI_MODEL=openai/gpt-5-mini

# Claude Code push endpoint (required for YouTube / Podcast ingestion)
AI_RADAR_INGEST_SECRET=
